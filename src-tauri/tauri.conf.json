{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentControl Bridge Installer",
  "version": "0.0.13",
  "identifier": "dev.agentcontrol.bridge-installer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentControl Bridge Installer",
        "width": 980,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": { "csp": null }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["agentcontrol-bridge-installer"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "appimage"],
    "category": "DeveloperTool",
    "shortDescription": "Install AgentControl Bridge with one wizard",
    "longDescription": "Real installer for the AgentControl Bridge. Sets up WSL2 + Ubuntu on Windows, installs Node and Claude Code CLI, configures git, downloads the bridge, generates a fresh API key and walks you through pairing — no Tailscale dependency.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
